<!DOCTYPE html>
<html lang="pt-BR">
<head>

<meta charset="UTF-8">
<title>Painel Financeiro</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:system-ui;
}

body{
background:#0f172a;
color:white;
padding:30px;
}

.container{
max-width:1400px;
margin:auto;
}

h1{
margin-bottom:25px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-bottom:30px;
}

.card{
background:#1e293b;
padding:20px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.5);
}

.card h3{
font-size:13px;
opacity:.7;
margin-bottom:6px;
}

.card span{
font-size:24px;
font-weight:bold;
}

section{
margin-top:40px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:15px;
}

th,td{
padding:10px;
border-bottom:1px solid #334155;
}

th{
opacity:.7;
}

input{
padding:8px;
border-radius:6px;
border:none;
}

button{
padding:8px 14px;
border:none;
border-radius:6px;
background:#2563eb;
color:white;
cursor:pointer;
}

button:hover{
opacity:.9;
}

.form{
display:flex;
flex-wrap:wrap;
gap:8px;
margin-top:10px;
}

.status{
padding:4px 8px;
border-radius:6px;
font-size:12px;
}

.estoque{background:#334155;}
.vendido{background:#16a34a;}
.ativa{background:#334155;}
.contemplada{background:#9333ea;}

.lucro{color:#22c55e;}
.prejuizo{color:#ef4444;}

.chart-box{
background:#1e293b;
padding:20px;
border-radius:12px;
margin-top:40px;
}

.export{
margin-top:10px;
}

</style>
</head>

<body>

<div class="container">

<h1>Painel Financeiro</h1>

<div class="cards">

<div class="card">
<h3>Investimento Total</h3>
<span id="investimento">R$0</span>
</div>

<div class="card">
<h3>Lucro Total</h3>
<span id="lucroTotal">R$0</span>
</div>

<div class="card">
<h3>ROI</h3>
<span id="roi">0%</span>
</div>

<div class="card">
<h3>Aparelhos Estoque</h3>
<span id="estoque">0</span>
</div>

<div class="card">
<h3>Cartas Ativas</h3>
<span id="cartasAtivas">0</span>
</div>

</div>

<section>

<h2>Aparelhos</h2>

<div class="form">

<input id="modelo" placeholder="Modelo">
<input id="dataCompra" type="date">
<input id="valorPago" type="number" placeholder="Valor Pago">

<button onclick="addAparelho()">Cadastrar</button>

</div>

<button class="export" onclick="exportAparelhos()">Exportar CSV</button>

<table>

<thead>
<tr>
<th>Modelo</th>
<th>Compra</th>
<th>Pago</th>
<th>Venda</th>
<th>Status</th>
<th>Lucro</th>
<th>Ação</th>
</tr>
</thead>

<tbody id="tabelaAparelhos"></tbody>

</table>

</section>

<section>

<h2>Cartas</h2>

<div class="form">

<input id="valorCarta" type="number" placeholder="Valor Carta">
<input id="adesao" type="number" placeholder="Adesão">
<input id="parcela" type="number" placeholder="Parcela">
<input id="mesInicio" type="number" placeholder="Mês Inicial">

<button onclick="addCarta()">Cadastrar</button>

</div>

<button class="export" onclick="exportCartas()">Exportar CSV</button>

<table>

<thead>
<tr>
<th>Valor</th>
<th>Parcela</th>
<th>Inicio</th>
<th>Contemplação</th>
<th>Total Pago</th>
<th>Venda</th>
<th>Lucro</th>
<th>Status</th>
<th>Ação</th>
</tr>
</thead>

<tbody id="tabelaCartas"></tbody>

</table>

</section>

<div class="chart-box">

<h2>Lucro Mensal</h2>

<canvas id="grafico"></canvas>

</div>

</div>

<script>

let aparelhos=JSON.parse(localStorage.getItem("aparelhos"))||[]
let cartas=JSON.parse(localStorage.getItem("cartas"))||[]

function salvar(){
localStorage.setItem("aparelhos",JSON.stringify(aparelhos))
localStorage.setItem("cartas",JSON.stringify(cartas))
render()
}

function format(v){
return v.toLocaleString("pt-BR",{style:"currency",currency:"BRL"})
}

function addAparelho(){

let modelo=document.getElementById("modelo").value
let dataCompra=document.getElementById("dataCompra").value
let valorPago=parseFloat(document.getElementById("valorPago").value)

if(!modelo||!valorPago)return

aparelhos.push({
id:Date.now(),
modelo,
dataCompra,
valorPago,
valorVenda:null,
status:"Estoque"
})

salvar()
}

function venderAparelho(id){

let valor=prompt("Valor venda")

let a=aparelhos.find(a=>a.id==id)

a.valorVenda=parseFloat(valor)
a.status="Vendido"

salvar()

}

function addCarta(){

let valorCarta=parseFloat(valorCartaInput.value)
let adesao=parseFloat(adesaoInput.value)
let parcela=parseFloat(parcelaInput.value)
let mesInicio=parseInt(mesInicioInput.value)

cartas.push({
id:Date.now(),
valorCarta,
adesao,
parcela,
mesInicio,
mesContemplacao:null,
valorVenda:null,
status:"Ativa"
})

salvar()

}

function contemplarCarta(id){

let mes=prompt("Mês contemplação")
let venda=prompt("Valor venda")

let c=cartas.find(c=>c.id==id)

c.mesContemplacao=parseInt(mes)
c.valorVenda=parseFloat(venda)
c.status="Contemplada"

salvar()

}

function calcularMensal(){

let meses={}

aparelhos.forEach(a=>{

if(a.status==="Vendido"){

let d=new Date(a.dataCompra)
let chave=d.getFullYear()+"-"+(d.getMonth()+1)

let lucro=a.valorVenda-a.valorPago

if(!meses[chave])meses[chave]=0

meses[chave]+=lucro

}

})

cartas.forEach(c=>{

if(c.status==="Contemplada"){

let chave="Mes-"+c.mesContemplacao

let mesesPagos=c.mesContemplacao-c.mesInicio

let pago=c.adesao+(c.parcela*mesesPagos)

let lucro=c.valorVenda-pago

if(!meses[chave])meses[chave]=0

meses[chave]+=lucro

}

})

return meses

}

let chart

function grafico(){

let dados=calcularMensal()

let labels=[]
let valores=[]

Object.keys(dados).forEach(m=>{

labels.push(m)
valores.push(dados[m])

})

if(chart)chart.destroy()

chart=new Chart(
document.getElementById("grafico"),
{
type:"bar",
data:{
labels:labels,
datasets:[
{
label:"Lucro Mensal",
data:valores
}
]
}
})

}

function render(){

let investimento=0
let lucroTotal=0
let estoque=0
let cartasAtivas=0

let tabela=""

aparelhos.forEach(a=>{

let lucro=0

investimento+=a.valorPago

if(a.status==="Vendido"){

lucro=a.valorVenda-a.valorPago
lucroTotal+=lucro

}else{
estoque++
}

tabela+=`

<tr>

<td>${a.modelo}</td>
<td>${a.dataCompra||"-"}</td>
<td>${format(a.valorPago)}</td>
<td>${a.valorVenda?format(a.valorVenda):"-"}</td>

<td>
<span class="status ${a.status==="Estoque"?"estoque":"vendido"}">
${a.status}
</span>
</td>

<td class="${lucro>=0?"lucro":"prejuizo"}">
${a.status==="Vendido"?format(lucro):"-"}
</td>

<td>

${a.status==="Estoque"?
`<button onclick="venderAparelho(${a.id})">Vender</button>`:""}

</td>

</tr>

`

})

tabelaAparelhos.innerHTML=tabela

let tabelaC=""

cartas.forEach(c=>{

let totalPago=0
let lucro=0

if(c.status==="Contemplada"){

let meses=c.mesContemplacao-c.mesInicio

totalPago=c.adesao+(c.parcela*meses)

lucro=c.valorVenda-totalPago

lucroTotal+=lucro

}else{

cartasAtivas++

}

tabelaC+=`

<tr>

<td>${format(c.valorCarta)}</td>
<td>${format(c.parcela)}</td>
<td>${c.mesInicio}</td>
<td>${c.mesContemplacao||"-"}</td>
<td>${totalPago?format(totalPago):"-"}</td>
<td>${c.valorVenda?format(c.valorVenda):"-"}</td>

<td class="${lucro>=0?"lucro":"prejuizo"}">
${lucro?format(lucro):"-"}
</td>

<td>
<span class="status ${c.status==="Ativa"?"ativa":"contemplada"}">
${c.status}
</span>
</td>

<td>

${c.status==="Ativa"?
`<button onclick="contemplarCarta(${c.id})">Contemplar</button>`:""}

</td>

</tr>

`

})

tabelaCartas.innerHTML=tabelaC

let roi=((lucroTotal/investimento)*100)||0

investimentoEl.innerText=format(investimento)
lucroTotalEl.innerText=format(lucroTotal)
roiEl.innerText=roi.toFixed(1)+"%"

estoqueEl.innerText=estoque
cartasAtivasEl.innerText=cartasAtivas

grafico()

}

const tabelaAparelhos=document.getElementById("tabelaAparelhos")
const tabelaCartas=document.getElementById("tabelaCartas")

const investimentoEl=document.getElementById("investimento")
const lucroTotalEl=document.getElementById("lucroTotal")
const roiEl=document.getElementById("roi")

const estoqueEl=document.getElementById("estoque")
const cartasAtivasEl=document.getElementById("cartasAtivas")

const valorCartaInput=document.getElementById("valorCarta")
const adesaoInput=document.getElementById("adesao")
const parcelaInput=document.getElementById("parcela")
const mesInicioInput=document.getElementById("mesInicio")

render()

</script>

</body>
</html>
