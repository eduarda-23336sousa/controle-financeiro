<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Dashboard Investimentos</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>

*{
box-sizing:border-box;
margin:0;
padding:0;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:#0f172a;
color:#fff;
padding:30px;
}

h1{
margin-bottom:20px;
}

.container{
max-width:1400px;
margin:auto;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:40px;
}

.card{
background:#1e293b;
padding:20px;
border-radius:10px;
opacity:.95;
}

.card h3{
font-size:14px;
opacity:.7;
margin-bottom:10px;
}

.card span{
font-size:28px;
font-weight:bold;
}

section{
margin-top:40px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:15px;
}

th,td{
padding:10px;
text-align:left;
border-bottom:1px solid #334155;
}

th{
opacity:.8;
}

input{
padding:8px;
border-radius:6px;
border:none;
margin-right:5px;
}

button{
padding:8px 14px;
border:none;
border-radius:6px;
background:#2563eb;
color:white;
cursor:pointer;
}

button:hover{
opacity:.9;
}

.grid-form{
display:flex;
flex-wrap:wrap;
gap:8px;
margin-top:10px;
}

.status{
padding:4px 8px;
border-radius:6px;
font-size:12px;
}

.estoque{
background:#334155;
}

.vendido{
background:#16a34a;
}

.ativa{
background:#334155;
}

.contemplada{
background:#9333ea;
}

.lucro{
color:#22c55e;
font-weight:bold;
}

.prejuizo{
color:#ef4444;
font-weight:bold;
}

</style>

</head>

<body>

<div class="container">

<h1>Dashboard de Investimentos</h1>

<div class="cards">

<div class="card">
<h3>Aparelhos em Estoque</h3>
<span id="estoque">0</span>
</div>

<div class="card">
<h3>Aparelhos Vendidos</h3>
<span id="vendidos">0</span>
</div>

<div class="card">
<h3>Cartas Ativas</h3>
<span id="cartasAtivas">0</span>
</div>

<div class="card">
<h3>Cartas Contempladas</h3>
<span id="cartasContempladas">0</span>
</div>

<div class="card">
<h3>Lucro Aparelhos</h3>
<span id="lucroAparelhos">R$0</span>
</div>

<div class="card">
<h3>Lucro Cartas</h3>
<span id="lucroCartas">R$0</span>
</div>

<div class="card">
<h3>Lucro Total</h3>
<span id="lucroTotal">R$0</span>
</div>

</div>

<section>

<h2>Aparelhos</h2>

<div class="grid-form">

<input id="modelo" placeholder="Modelo">
<input id="dataCompra" type="date">
<input id="valorPago" type="number" placeholder="Valor Pago">

<button onclick="addAparelho()">Cadastrar</button>

</div>

<table>

<thead>
<tr>
<th>Modelo</th>
<th>Compra</th>
<th>Pago</th>
<th>Venda</th>
<th>Status</th>
<th>Lucro</th>
<th>Ação</th>
</tr>
</thead>

<tbody id="tabelaAparelhos"></tbody>

</table>

</section>

<section>

<h2>Cartas</h2>

<div class="grid-form">

<input id="valorCarta" type="number" placeholder="Valor Carta">
<input id="adesao" type="number" placeholder="Adesão">
<input id="parcela" type="number" placeholder="Parcela">
<input id="mesInicio" type="number" placeholder="Mês Inicial">

<button onclick="addCarta()">Cadastrar</button>

</div>

<table>

<thead>
<tr>
<th>Valor Carta</th>
<th>Parcela</th>
<th>Mês Inicial</th>
<th>Mês Contemplação</th>
<th>Total Pago</th>
<th>Venda</th>
<th>Lucro</th>
<th>Status</th>
<th>Ação</th>
</tr>
</thead>

<tbody id="tabelaCartas"></tbody>

</table>

</section>

</div>

<script>

let aparelhos=JSON.parse(localStorage.getItem("aparelhos"))||[]
let cartas=JSON.parse(localStorage.getItem("cartas"))||[]

function salvar(){
localStorage.setItem("aparelhos",JSON.stringify(aparelhos))
localStorage.setItem("cartas",JSON.stringify(cartas))
render()
}

function format(v){
return v.toLocaleString("pt-BR",{style:"currency",currency:"BRL"})
}

function addAparelho(){

let modelo=document.getElementById("modelo").value
let dataCompra=document.getElementById("dataCompra").value
let valorPago=parseFloat(document.getElementById("valorPago").value)

if(!modelo||!valorPago)return

aparelhos.push({
id:Date.now(),
modelo,
dataCompra,
valorPago,
valorVenda:null,
status:"Estoque"
})

salvar()

}

function venderAparelho(id){

let valor=prompt("Valor da venda")

if(!valor)return

let ap=aparelhos.find(a=>a.id==id)

ap.valorVenda=parseFloat(valor)
ap.status="Vendido"

salvar()

}

function addCarta(){

let valorCarta=parseFloat(document.getElementById("valorCarta").value)
let adesao=parseFloat(document.getElementById("adesao").value)
let parcela=parseFloat(document.getElementById("parcela").value)
let mesInicio=parseInt(document.getElementById("mesInicio").value)

cartas.push({
id:Date.now(),
valorCarta,
adesao,
parcela,
mesInicio,
mesContemplacao:null,
valorVenda:null,
status:"Ativa"
})

salvar()

}

function contemplarCarta(id){

let mes=prompt("Mês da contemplação")
let venda=prompt("Valor da venda da carta")

let c=cartas.find(c=>c.id==id)

c.mesContemplacao=parseInt(mes)
c.valorVenda=parseFloat(venda)
c.status="Contemplada"

salvar()

}

function render(){

let estoque=0
let vendidos=0
let lucroAparelhos=0

let tabelaAparelhos=""

aparelhos.forEach(a=>{

let lucro=0

if(a.status==="Vendido"){
lucro=a.valorVenda-a.valorPago
lucroAparelhos+=lucro
vendidos++
}else{
estoque++
}

tabelaAparelhos+=`

<tr>

<td>${a.modelo}</td>
<td>${a.dataCompra||"-"}</td>
<td>${format(a.valorPago)}</td>
<td>${a.valorVenda?format(a.valorVenda):"-"}</td>

<td>
<span class="status ${a.status==="Estoque"?"estoque":"vendido"}">
${a.status}
</span>
</td>

<td class="${lucro>=0?"lucro":"prejuizo"}">
${a.status==="Vendido"?format(lucro):"-"}
</td>

<td>
${a.status==="Estoque"?
`<button onclick="venderAparelho(${a.id})">Vender</button>`
:""}
</td>

</tr>

`

})

document.getElementById("tabelaAparelhos").innerHTML=tabelaAparelhos

let cartasAtivas=0
let cartasContempladas=0
let lucroCartas=0

let tabelaCartas=""

cartas.forEach(c=>{

let totalPago=0
let lucro=0

if(c.status==="Contemplada"){

let meses=c.mesContemplacao-c.mesInicio

totalPago=c.adesao+(c.parcela*meses)

lucro=c.valorVenda-totalPago

lucroCartas+=lucro
cartasContempladas++

}else{

cartasAtivas++

}

tabelaCartas+=`

<tr>

<td>${format(c.valorCarta)}</td>
<td>${format(c.parcela)}</td>

<td>${c.mesInicio}</td>

<td>${c.mesContemplacao||"-"}</td>

<td>${totalPago?format(totalPago):"-"}</td>

<td>${c.valorVenda?format(c.valorVenda):"-"}</td>

<td class="${lucro>=0?"lucro":"prejuizo"}">
${lucro?format(lucro):"-"}
</td>

<td>
<span class="status ${c.status==="Ativa"?"ativa":"contemplada"}">
${c.status}
</span>
</td>

<td>
${c.status==="Ativa"?
`<button onclick="contemplarCarta(${c.id})">Contemplar</button>`
:""}
</td>

</tr>

`

})

document.getElementById("tabelaCartas").innerHTML=tabelaCartas

document.getElementById("estoque").innerText=estoque
document.getElementById("vendidos").innerText=vendidos
document.getElementById("cartasAtivas").innerText=cartasAtivas
document.getElementById("cartasContempladas").innerText=cartasContempladas

document.getElementById("lucroAparelhos").innerText=format(lucroAparelhos)
document.getElementById("lucroCartas").innerText=format(lucroCartas)
document.getElementById("lucroTotal").innerText=format(lucroAparelhos+lucroCartas)

}

render()

</script>

</body>
</html>
